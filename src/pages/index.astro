---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mohammad Talha | Software Engineer</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      /* Enforces smooth scrolling across all browsers */
      html {
        scroll-behavior: smooth !important;
      }
      body {
        font-family: "Inter", sans-serif;
        background-color: #ffffff;
        color: #1d1d1f;
      }

      /* Custom Modal Backdrop Styling */
      dialog::backdrop {
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
      }

      /* Custom Smooth Floating Animations */
      @keyframes float {
        0%,
        100% {
          transform: translateY(0px) rotate(0deg);
        }
        50% {
          transform: translateY(-20px) rotate(4deg);
        }
      }
      .animate-float {
        animation: float 7s ease-in-out infinite;
      }
      .animate-float-delayed {
        animation: float 9s ease-in-out infinite 3s;
      }
      .animate-float-slow {
        animation: float 12s ease-in-out infinite 1s;
      }

      /* Hide scrollbar for Apple-like horizontal carousels */
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </head>
  <body class="antialiased relative z-0">
    <!-- Apple-style Sticky Navigation Bar -->
    <nav
      class="fixed top-0 left-0 w-full z-50 bg-[#1d1d1f]/85 backdrop-blur-md border-b border-white/10 text-white"
    >
      <div
        class="max-w-4xl mx-auto px-6 py-4 flex justify-between items-center gap-6"
      >
        <!-- shrink-0 keeps the MT logo from being squished -->
        <a
          href="#"
          class="font-extrabold tracking-tight text-lg hover:text-gray-300 transition-colors shrink-0"
          >MT.</a
        >

        <!-- Swipeable Mobile Menu -->
        <div
          class="flex gap-6 md:gap-8 text-sm font-semibold tracking-wide overflow-x-auto no-scrollbar whitespace-nowrap scroll-smooth"
        >
          <a href="#projects" class="hover:text-gray-400 transition-colors"
            >Projects</a
          >
          <a
            href="#certifications"
            class="hover:text-gray-400 transition-colors"
            >Certifications & Awards</a
          >
          <a href="#volunteering" class="hover:text-gray-400 transition-colors"
            >Volunteering</a
          >
          <a href="#socials" class="hover:text-gray-400 transition-colors"
            >Socials</a
          >
        </div>
      </div>
    </nav>

    <!-- Decorative Background Layer (Hidden on Mobile) -->
    <div
      class="fixed inset-0 pointer-events-none z-[-1] overflow-hidden hidden lg:block"
    >
      <div
        class="absolute top-[-10%] left-[-10%] w-[40rem] h-[40rem] bg-gray-50 rounded-full blur-3xl opacity-80"
      >
      </div>
      <div
        class="absolute top-[40%] right-[-10%] w-[35rem] h-[35rem] bg-blue-50/50 rounded-full blur-3xl opacity-80"
      >
      </div>
      <div
        class="absolute top-[15%] left-[10%] text-4xl opacity-30 animate-float grayscale hover:grayscale-0 transition-all duration-500"
      >
        👨‍💻
      </div>
      <div
        class="absolute top-[35%] right-[12%] text-5xl opacity-20 animate-float-delayed grayscale hover:grayscale-0 transition-all duration-500"
      >
        🚀
      </div>
      <div
        class="absolute top-[65%] left-[8%] text-4xl opacity-20 animate-float-slow grayscale hover:grayscale-0 transition-all duration-500"
      >
        💡
      </div>
      <div
        class="absolute top-[20%] right-[18%] text-3xl opacity-30 animate-float grayscale hover:grayscale-0 transition-all duration-500"
      >
        ⚙️
      </div>
      <div
        class="absolute top-[75%] right-[10%] text-4xl opacity-20 animate-float-delayed grayscale hover:grayscale-0 transition-all duration-500"
      >
        📱
      </div>
    </div>

    <!-- Main Content Area -->
    <div class="max-w-4xl mx-auto px-6 pb-12 pt-32 md:pt-40">
      <!-- Hero Section -->
      <header class="mb-20">
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6">
          Hi, I'm Talha 👨‍💻
        </h1>
        <p
          class="text-xl md:text-2xl text-gray-500 font-medium max-w-2xl leading-relaxed"
        >
          Software Engineering student specializing in bridging robust
          architecture with AI. Building intelligent, user-centric digital
          solutions.
        </p>
      </header>

      <main class="space-y-8">
        <!-- Bento Grid: Skills & About -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <section
            class="bg-[#f5f5f7]/80 backdrop-blur-sm p-8 rounded-[2rem] transform transition-all duration-300 ease-out hover:scale-[1.02] hover:shadow-md"
          >
            <h2 class="text-xl font-bold mb-4">🚀 Expertise</h2>
            <p class="text-gray-600 leading-relaxed">
              AI Automation Engineer at SRKK Group. Focused on Microsoft Power
              Platform, Copilot Studio, and Azure OpenAI to drive enterprise
              digital transformation.
            </p>
          </section>

          <section
            class="bg-[#f5f5f7]/80 backdrop-blur-sm p-8 rounded-[2rem] transform transition-all duration-300 ease-out hover:scale-[1.02] hover:shadow-md"
          >
            <h2 class="text-xl font-bold mb-4">🛠️ Tech Stack</h2>
            <div class="flex flex-wrap gap-2">
              {
                [
                  "Kotlin",
                  "Python",
                  "TypeScript",
                  "React",
                  "Jetpack Compose",
                  "SQL",
                  "Java",
                ].map((tech) => (
                  <span class="bg-white px-3 py-1 rounded-full text-sm font-semibold border border-gray-100 shadow-sm hover:shadow transition-shadow">
                    {tech}
                  </span>
                ))
              }
            </div>
          </section>
        </div>

        <!-- Experience Section -->
        <section
          class="bg-[#f5f5f7]/80 backdrop-blur-sm p-8 rounded-[2rem] transform transition-all duration-300 ease-out hover:scale-[1.01] hover:shadow-md"
        >
          <h2 class="text-2xl font-bold mb-6">💼 Experience</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-bold text-lg">AI Automation Engineer (Intern)</h3>
              <p class="text-gray-500 font-medium">
                SRKK Group | Jun 2026 - Present
              </p>
            </div>
          </div>
        </section>

        <!-- Education Section -->
        <section
          class="bg-[#f5f5f7]/80 backdrop-blur-sm p-8 rounded-[2rem] transform transition-all duration-300 ease-out hover:scale-[1.01] hover:shadow-md"
        >
          <h2 class="text-2xl font-bold mb-6">👨🏼‍🎓 Education</h2>
          <div class="space-y-6">
            <!-- SEGi Block -->
            <div>
              <h3 class="font-bold text-lg">
                SEGi University & University of Central Lancashire
              </h3>
              <p class="text-gray-500 font-medium mb-3">
                BSc (Hons) Information Technology (Software Engineering) | 2023
                - 2026
              </p>
              <button
                onclick="document.getElementById('clubsModal').showModal()"
                class="inline-flex items-center gap-2 bg-white px-4 py-2 rounded-full border border-gray-200 text-sm font-bold hover:border-gray-400 hover:shadow-sm transition-all text-gray-700"
              >
                <span>View Clubs & Leadership ↗</span>
              </button>
            </div>

            <!-- Sunshine Grammar School Block with new Modal Button -->
            <div class="border-t border-gray-200 pt-4">
              <h3 class="font-bold text-lg">Sunshine Grammar School</h3>
              <p class="text-gray-500 font-medium mb-3">Oct 2019 - Oct 2022</p>
              <button
                onclick="document.getElementById('schoolModal').showModal()"
                class="inline-flex items-center gap-2 bg-white px-4 py-2 rounded-full border border-gray-200 text-sm font-bold hover:border-gray-400 hover:shadow-sm transition-all text-gray-700"
              >
                <span>View Academic Qualifications ↗</span>
              </button>
            </div>
          </div>
        </section>

        <!-- Languages Section -->
        <section
          class="bg-[#f5f5f7]/80 backdrop-blur-sm p-8 rounded-[2rem] transform transition-all duration-300 ease-out hover:scale-[1.01] hover:shadow-md"
        >
          <h2 class="text-2xl font-bold mb-6">🗣️ Languages</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {
              languagesData.map((lang) => (
                <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm flex flex-col justify-center transform transition-transform hover:scale-[1.02]">
                  <h3 class="font-bold text-gray-900">{lang.name}</h3>
                  <p class="text-gray-500 text-sm mt-1">{lang.proficiency}</p>
                </div>
              ))
            }
          </div>
        </section>

        <!-- Certifications Section (Apple-Style Slider) -->
        <section
          id="certifications"
          class="scroll-mt-28 bg-[#f5f5f7]/80 backdrop-blur-sm p-8 rounded-[2rem] transform transition-all duration-300 ease-out hover:scale-[1.01] hover:shadow-md overflow-hidden relative"
        >
          <div class="mb-6">
            <h2 class="text-2xl font-bold">📜 Certifications</h2>
          </div>

          <div class="relative w-full">
            <!-- Scrollable Cards -->
            <div
              id="certSlider"
              class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-6 no-scrollbar scroll-smooth"
            >
              {
                certsData.map((cert) => (
                  <div class="shrink-0 w-[85%] md:w-[320px] snap-center bg-white p-8 rounded-3xl border border-gray-100 shadow-sm flex flex-col justify-between min-h-[200px]">
                    <div>
                      <h3 class="font-bold text-lg leading-tight text-gray-900 mb-3">
                        {cert.title}
                      </h3>
                      <p class="text-gray-500 font-medium">{cert.issuer}</p>
                    </div>
                    <div class="mt-6 border-t border-gray-100 pt-4">
                      <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">
                        Issued: {cert.date}
                      </p>
                    </div>
                  </div>
                ))
              }
            </div>

            <!-- Apple-style Pagination Pill -->
            <div class="flex justify-center mt-2">
              <div
                class="bg-[#1d1d1f]/85 backdrop-blur-md px-5 py-2.5 rounded-full flex items-center gap-5 shadow-lg border border-white/10"
              >
                <!-- Prev Button -->
                <button
                  id="cert-prev"
                  class="text-white/50 hover:text-white transition-colors flex items-center justify-center cursor-pointer"
                  aria-label="Previous Certification"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                    class="w-5 h-5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M15.75 19.5L8.25 12l7.5-7.5"></path>
                  </svg>
                </button>

                <!-- Progress Bar -->
                <div
                  class="h-1.5 w-16 bg-white/20 rounded-full overflow-hidden relative"
                >
                  <div
                    id="cert-progress"
                    class="absolute top-0 left-0 h-full bg-white rounded-full w-1/3 transition-transform duration-150 ease-out"
                  >
                  </div>
                </div>

                <!-- Next Button -->
                <button
                  id="cert-next"
                  class="text-white/50 hover:text-white transition-colors flex items-center justify-center cursor-pointer"
                  aria-label="Next Certification"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                    class="w-5 h-5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M8.25 4.5l7.5 7.5-7.5 7.5"></path>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </section>

        <!-- Awards Section (Triggers Modal) -->
        <section
          id="awards"
          class="bg-[#f5f5f7]/80 backdrop-blur-sm p-8 rounded-[2rem] transform transition-all duration-300 ease-out hover:scale-[1.01] hover:shadow-md"
        >
          <h2 class="text-2xl font-bold mb-6">🏆 Awards & Recognition</h2>
          <button
            onclick="document.getElementById('awardModal').showModal()"
            class="w-full text-left block bg-white p-6 rounded-2xl border border-gray-100 hover:border-blue-500 transition-all group shadow-sm hover:shadow-md relative overflow-hidden"
          >
            <div
              class="absolute top-0 left-0 w-2 h-full bg-gradient-to-b from-yellow-400 to-yellow-600 group-hover:w-3 transition-all duration-300"
            >
            </div>
            <div class="pl-4">
              <h3
                class="font-bold text-xl group-hover:text-blue-600 transition-colors flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2"
              >
                Best Degree Project Award
                <span
                  class="text-gray-400 group-hover:text-blue-600 bg-gray-50 px-3 py-1 rounded-full text-sm self-start sm:self-auto whitespace-nowrap"
                  >View Details ↗</span
                >
              </h3>
              <p class="text-gray-500 text-sm mt-2 font-medium">
                Technovation 2026 • SEGi University
              </p>
              <p class="text-gray-400 text-sm mt-1">
                Awarded for BiteWise, a commercial-grade offline-first native
                Android application.
              </p>
            </div>
          </button>
        </section>

        <!-- Volunteering Section (Triggers Modal with Dynamic Array Counting) -->
        <section
          id="volunteering"
          class="scroll-mt-28 bg-[#f5f5f7]/80 backdrop-blur-sm p-8 rounded-[2rem] flex flex-col md:flex-row justify-between items-center gap-6 transform transition-all duration-300 ease-out hover:scale-[1.01] hover:shadow-md"
        >
          <div>
            <h2 class="text-2xl font-bold mb-2">🤝 Volunteering</h2>
            <p class="text-gray-600 font-medium">
              <span class="font-bold text-black">{volunteerData.length}</span> community
              engagements and active event operations.
            </p>
          </div>
          <button
            onclick="document.getElementById('volunteerModal').showModal()"
            class="bg-[#1d1d1f] text-white px-8 py-4 rounded-full font-bold hover:bg-gray-800 transition-all shadow-md hover:shadow-lg whitespace-nowrap"
          >
            View All Experience
          </button>
        </section>
      </main>
    </div>

    <!-- Dark Section (Projects & Footer) -->
    <div
      id="projects"
      class="scroll-mt-20 bg-[#1d1d1f] text-white py-24 px-6 relative z-10"
    >
      <div class="max-w-4xl mx-auto">
        <div class="mb-12">
          <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight">
            Featured Engineering ⚡
          </h2>
          <p class="text-gray-400 mt-2 text-lg font-medium">
            Turning architectural constraints into seamless products.
          </p>
        </div>

        <section
