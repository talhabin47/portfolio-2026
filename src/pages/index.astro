    <!-- Global Scripts -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        // --- 1. Modal Background Scroll Lock ---
        const dialogs = document.querySelectorAll("dialog");
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.attributeName === "open") {
              if (
                mutation.target instanceof Element &&
                mutation.target.hasAttribute("open")
              ) {
                document.body.style.overflow = "hidden";
              } else {
                document.body.style.overflow = "";
              }
            }
          });
        });

        dialogs.forEach((dialog) => {
          observer.observe(dialog, { attributes: true });
          dialog.addEventListener("click", (e) => {
            const rect = dialog.getBoundingClientRect();
            const isInDialog =
              rect.top <= e.clientY &&
              e.clientY <= rect.top + rect.height &&
              rect.left <= e.clientX &&
              e.clientX <= rect.left + rect.width;
            if (!isInDialog) {
              dialog.close();
            }
          });
        });

        // --- 2. Apple-Style Slider Logic ---
        const certSlider = document.getElementById("certSlider");
        const certProgress = document.getElementById("cert-progress");
        const certPrev = document.getElementById("cert-prev");
        const certNext = document.getElementById("cert-next");

        if (certSlider && certProgress && certPrev && certNext) {
          const updateSliderUI = () => {
            const maxScroll = certSlider.scrollWidth - certSlider.clientWidth;
            const scrollPercent =
              maxScroll > 0 ? certSlider.scrollLeft / maxScroll : 0;
            // The indicator width is 1/3, meaning it can translate up to 200% of its own width
            certProgress.style.transform = `translateX(${scrollPercent * 200}%)`;
          };

          certSlider.addEventListener("scroll", updateSliderUI, {
            passive: true,
          });
          window.addEventListener("resize", updateSliderUI);

          certPrev.addEventListener("click", () => {
            // Find the width of one card + the gap (24px)
            const firstCard = certSlider.querySelector("div");
            if (firstCard) {
              const cardWidth = firstCard.offsetWidth + 24;
              certSlider.scrollBy({ left: -cardWidth, behavior: "smooth" });
            }
          });

          certNext.addEventListener("click", () => {
            const firstCard = certSlider.querySelector("div");
            if (firstCard) {
              const cardWidth = firstCard.offsetWidth + 24;
              certSlider.scrollBy({ left: cardWidth, behavior: "smooth" });
            }
          });

          // Initialize
          updateSliderUI();
        }
      });
    </script>
